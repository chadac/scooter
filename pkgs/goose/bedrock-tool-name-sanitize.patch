 use serde_json::Value;
 
+use std::sync::Mutex;
+use std::sync::OnceLock;
+
+/// Bedrock requires tool names to match `^[a-zA-Z0-9_-]+$` (<=64 chars). Goose can
+/// surface an MCP tool's DISPLAY name ("<Extension>: <Title Case>") into a message's
+/// tool_call.name — notably on session resume, when persisted messages are reloaded
+/// — and that name (spaces, ":") fails Bedrock validation. We sanitize the name on
+/// the way OUT and keep a lossless sanitized->original map so the name Bedrock echoes
+/// back in its response is restored before we dispatch the tool to MCP.
+fn bedrock_tool_name_map() -> &'static Mutex<HashMap<String, String>> {
+    static MAP: OnceLock<Mutex<HashMap<String, String>>> = OnceLock::new();
+    MAP.get_or_init(|| Mutex::new(HashMap::new()))
+}
+
+/// Replace every char outside `[a-zA-Z0-9_-]` with `_`, collapse runs of `_`, and
+/// trim leading/trailing `_`. Deterministic + idempotent (an already-valid name is
+/// returned unchanged), so re-sanitizing a resumed request is stable.
+fn sanitize_bedrock_tool_name(name: &str) -> String {
+    let mut out = String::with_capacity(name.len());
+    let mut last_us = false;
+    for c in name.chars() {
+        if c.is_ascii_alphanumeric() || c == '-' {
+            out.push(c);
+            last_us = false;
+        } else if !last_us {
+            out.push('_');
+            last_us = true;
+        }
+    }
+    let trimmed = out.trim_matches('_');
+    let mut s = if trimmed.is_empty() { "tool".to_string() } else { trimmed.to_string() };
+    if s.len() > 64 {
+        s.truncate(64);
+    }
+    s
+}
+
+/// Sanitize a tool name for the Bedrock wire and remember the mapping so the
+/// response decode can restore the original.
+fn to_bedrock_tool_name(name: &str) -> String {
+    let safe = sanitize_bedrock_tool_name(name);
+    if safe != name {
+        if let Ok(mut m) = bedrock_tool_name_map().lock() {
+            m.insert(safe.clone(), name.to_string());
+        }
+    }
+    safe
+}
+
+/// Restore the original tool name from a name Bedrock returned (the sanitized form),
+/// falling back to the given name when there's no mapping (already-valid names).
+fn from_bedrock_tool_name(name: &str) -> String {
+    bedrock_tool_name_map()
+        .lock()
+        .ok()
+        .and_then(|m| m.get(name).cloned())
+        .unwrap_or_else(|| name.to_string())
+}
+
