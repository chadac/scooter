+    #[test]
+    fn test_bedrock_tool_name_sanitize_roundtrip() {
+        // The mangled MCP display names from the bug report -> Bedrock-safe, and the
+        // sanitized name restores back to the original for MCP dispatch.
+        for original in [
+            "Scooter-env: Slack Respond",
+            "Scooter-env: Slack React",
+            "Todo: Todo Write",
+            "Scooter-aws Accounts",
+        ] {
+            let safe = to_bedrock_tool_name(original);
+            assert!(
+                safe.chars().all(|c| c.is_ascii_alphanumeric() || c == '_' || c == '-'),
+                "sanitized name {safe:?} still has invalid chars"
+            );
+            assert!(!safe.is_empty() && safe.len() <= 64);
+            assert_eq!(from_bedrock_tool_name(&safe), original, "restore must be lossless");
+        }
+    }
+
